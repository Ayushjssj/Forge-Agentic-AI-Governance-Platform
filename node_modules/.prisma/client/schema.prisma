generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  dir       String
  createdAt DateTime @default(now())
  runs      Run[]
}

model Run {
  id         String       @id @default(cuid())
  agentId    String
  agent      Agent        @relation(fields: [agentId], references: [id])
  prompt     String
  cost       Float?
  tokens     Int?
  duration   Int?
  sigmaScore Float?
  createdAt  DateTime     @default(now())
  scenarios  Scenario[]
  auditLog   AuditEntry[]
}

model Scenario {
  id      String  @id @default(cuid())
  runId   String
  run     Run     @relation(fields: [runId], references: [id])
  input   String
  output  String?
  verdict String
  score   Float
}

model AuditEntry {
  id        String   @id @default(cuid())
  runId     String
  run       Run      @relation(fields: [runId], references: [id])
  event     String
  payload   String
  createdAt DateTime @default(now())
}
